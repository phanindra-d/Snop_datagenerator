# PostgreSQL Database Configuration
# Copy this file to .env and fill in your credentials

# Local PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=snop_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# OR use full connection string (overrides above if set)
# DATABASE_URL=postgresql://username:password@hostname:5432/database_name

# Cloud PostgreSQL Examples:
# AWS RDS:       postgresql://user:pass@xxx.rds.amazonaws.com:5432/snop_db
# Azure:         postgresql://user:pass@xxx.postgres.database.azure.com:5432/snop_db
# Google Cloud:  postgresql://user:pass@xxx:5432/snop_db
# Supabase:      postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
# Neon:          postgresql://user:pass@xxx.neon.tech/snop_db

# Kaggle API Credentials (for Phase 4 - Historical Data)
# Get from https://www.kaggle.com/account → API → Create New API Token
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key
